# =============================================================================
# 10SHRTS Production Environment — Hetzner VPS
# =============================================================================
# Copy to .env.10shrts and fill in actual values before deployment.
# DO NOT commit this file with real credentials.
# =============================================================================

# ── Shared Infrastructure ──
POSTGRES_USER=medusa
POSTGRES_PASSWORD=           # Strong password here
POSTGRES_DB=db_10shrts
ACME_EMAIL=                  # Email for Let's Encrypt certificates

# ── Domains ──
STOREFRONT_DOMAIN_10SHRTS=10shrts.com
API_DOMAIN_10SHRTS=api.10shrts.com
ADMIN_DOMAIN_10SHRTS=admin.10shrts.com

# ── Medusa Backend ──
JWT_SECRET=                  # openssl rand -hex 32
COOKIE_SECRET=               # openssl rand -hex 32
DATABASE_URL=postgresql://medusa:CHANGE_ME@postgres:5432/db_10shrts
REDIS_URL=redis://redis:6379/0

# CORS
STORE_CORS=https://10shrts.com
ADMIN_CORS=https://admin.10shrts.com
AUTH_CORS=https://admin.10shrts.com

# ── Stripe ──
STRIPE_API_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_KEY_10SHRTS=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Shirtplatform ──
SHIRTPLATFORM_API_URL=
SHIRTPLATFORM_USERNAME=
SHIRTPLATFORM_PASSWORD=
SHIRTPLATFORM_ACCOUNT_ID=
SHIRTPLATFORM_SHOP_ID=

# ── Medusa Publishable Key ──
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY_10SHRTS=

# ── File Storage (Hetzner Object Storage) ──
FILE_S3_FILE_URL=
FILE_S3_ACCESS_KEY_ID=
FILE_S3_SECRET_ACCESS_KEY=
FILE_S3_REGION=fsn1
FILE_S3_BUCKET=
FILE_S3_ENDPOINT=
FILE_S3_PREFIX=10shrts/
HETZNER_S3_HOSTNAME=

# ── Storefront (build-time, also set in docker-compose.prod.yml) ──
MEDUSA_BACKEND_URL=https://api.10shrts.com
NEXT_PUBLIC_DEFAULT_REGION=dk
